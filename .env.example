# Firebase – create a project at https://console.firebase.google.com
# Enable Email/Password (and optionally Google) in Authentication → Sign-in method
# Create a Firestore database in Native mode
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Image generation — Option B (backend proxy) ───────────────────────────────
# Sign up at https://fal.ai and create an API key.
#
# Local dev:
#   FAL_KEY=your_fal_ai_key_here npm start
#   VITE_IMAGE_API_URL=/api/generate-image   ← Vite proxies /api/* to localhost:3001
#
# Production:
#   Deploy server/index.js, set FAL_KEY on the host, then set:
#   VITE_IMAGE_API_URL=https://your-server.onrender.com/api/generate-image
#
# Optional server-side LoRA defaults for the FLUX LoRA endpoint:
#   FAL_IMAGE_MODEL_URL=https://fal.run/fal-ai/flux-lora
#   FAL_CONFIG_URL=https://your-hosted-config.json
#   FAL_LORA_PATH=https://your-hosted-lora-file.safetensors
#   FAL_LORA_SCALE=1

VITE_IMAGE_API_URL=
FAL_IMAGE_MODEL_URL=https://fal.run/fal-ai/flux-lora
FAL_CONFIG_URL=
FAL_LORA_PATH=https://v3b.fal.media/files/b/0a961b80/LZYfVjdfVXWWb7gMl4kL2_pytorch_lora_weights.safetensors
FAL_LORA_SCALE=1

# ── Stripe payments ───────────────────────────────────────────────────────────
# Create a Stripe account at https://stripe.com and get your secret key from
# the Dashboard → Developers → API keys section.
# Use the test key (sk_test_...) during development.
STRIPE_SECRET_KEY=

# URL of the /api/create-checkout-session endpoint exposed by server/index.js.
# Local dev: leave unset — Vite proxies /api/* to localhost:3001 automatically.
# Production: optional if VITE_IMAGE_API_URL already points at the same proxy host;
# otherwise set to https://your-server.onrender.com/api/create-checkout-session
VITE_CHECKOUT_API_URL=https://your-server.onrender.com/api/create-checkout-session

# ── Admin access ──────────────────────────────────────────────────────────────
# Comma-separated list of Firebase Auth emails that have admin privileges.
# Admin users automatically receive the $10 (tier3) plan and can access /admin.
VITE_ADMIN_EMAILS=driver727@gmail.com

# Server-side copy — set this on the server host (e.g. Render dashboard) so the
# admin create-user endpoint can verify caller privileges.  Falls back to
# VITE_ADMIN_EMAILS for local dev.
ADMIN_EMAILS=driver727@gmail.com

# Firebase API key — required on the server for admin user creation via the
# Firebase Auth REST API.  Set this on the server host (e.g. Render dashboard).
# Falls back to VITE_FIREBASE_API_KEY for local dev.
FIREBASE_API_KEY=

# URL of the /api/admin/create-user endpoint exposed by server/index.js.
# Local dev: leave unset — Vite proxies /api/* to localhost:3001 automatically.
# Production: optional if VITE_IMAGE_API_URL already points at the same proxy host;
# otherwise set to https://your-server.onrender.com/api/admin/create-user
VITE_ADMIN_API_URL=
