rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Per-user cards ───────────────────────────────────────────────────────
    match /users/{uid}/cards/{cardId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Per-user decks ───────────────────────────────────────────────────────
    match /users/{uid}/decks/{deckId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Public user profiles (email look-up for trading) ─────────────────────
    match /userProfiles/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && (
        // Owners may always update their own profile
        request.auth.uid == uid
        // Admins (marked isAdmin: true in their own profile) may update any profile
        || (get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    // ── Image cache ──────────────────────────────────────────────────────────
    // Stores fal.ai-generated image URLs keyed by layer seed so repeated
    // requests for the same parameters never hit fal.ai again.
    // Anyone may read or create a cache entry; updates and deletes are blocked
    // so entries are effectively immutable once written.
    // The create rule validates document shape to prevent cache poisoning.
    match /imageCache/{cacheKey} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['imageUrl', 'createdAt'])
        && request.resource.data.imageUrl is string
        && request.resource.data.imageUrl.matches('https://.+');
      allow update, delete: if false;
    }

    // ── Trades ───────────────────────────────────────────────────────────────
    // Both parties can read; only the offerer can create;
    // only the recipient can update status (accept/decline),
    // and the offerer can cancel a pending trade.
    match /trades/{tradeId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid ||
        // Community Market: any signed-in player may browse pending listings
        resource.data.status == 'pending'
      );
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromUid;
      allow update: if request.auth != null && (
        // Recipient accepts/declines
        request.auth.uid == resource.data.toUid ||
        // Offerer cancels while still pending
        (request.auth.uid == resource.data.fromUid
          && resource.data.status == 'pending')
      );
    }
    // ── Referral Claims ──────────────────────────────────────────────────────
    // Written by any visitor who arrives via a referral link.
    // Doc ID format: {referrerUid}_{visitorKey}
    // - Anyone may create a claim (unauthenticated visitors included).
    // - Create is idempotent: if the doc already exists the write is silently
    //   rejected by the "no update" rule.
    // - Only the referrer (authenticated) may read their own claims.
    // - Self-referral is blocked: the write is allowed only when the visitor
    //   is unauthenticated OR is a different user than the referrer.
    match /referralClaims/{claimId} {
      allow read: if request.auth != null
        && resource.data.referrerUid == request.auth.uid;
      allow create: if request.resource.data.keys().hasOnly(['referrerUid', 'visitorKey', 'claimedAt'])
        && request.resource.data.referrerUid is string
        && request.resource.data.visitorKey is string
        // Prevent self-referral for authenticated visitors
        && (request.auth == null || request.auth.uid != request.resource.data.referrerUid);
      allow update, delete: if false;
    }

    // ── Battle Arena ─────────────────────────────────────────────────────────
    // Public arena listings.  Deck stats are NOT stored here — only metadata
    // (name, card count) so opponents cannot see private stats.
    // Any signed-in user can read all entries; only the owner can write/delete.
    match /arena/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && (
        request.auth.uid == uid
        // Allow the challenger to remove the defender's listing after battle
        || request.auth.uid != uid
      );
    }

    // ── Battle Results ───────────────────────────────────────────────────────
    // Any participant can read their own results; only authenticated users can create.
    match /battleResults/{resultId} {
      allow read:  if request.auth != null && (
        resource.data.challengerUid == request.auth.uid ||
        resource.data.defenderUid == request.auth.uid
      );
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
