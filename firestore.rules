rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Per-user cards ───────────────────────────────────────────────────────
    match /users/{uid}/cards/{cardId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Per-user decks ───────────────────────────────────────────────────────
    match /users/{uid}/decks/{deckId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Private user profiles ────────────────────────────────────────────────
    // Full profile docs are owner/admin readable only. Admin authority comes
    // from Firebase Auth custom claims, not from self-editable Firestore data.
    match /userProfiles/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || request.auth.token.admin == true);
      allow create: if request.auth != null && (
        (request.auth.uid == uid
          && request.resource.data.keys().hasOnly([
            'uid', 'email', 'emailLower', 'displayName', 'discoveredFactions', 'updatedAt'
          ]))
        || request.auth.token.admin == true
      );
      allow update: if request.auth != null && (
        (request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'email', 'emailLower', 'displayName', 'discoveredFactions', 'updatedAt'
          ]))
        || request.auth.token.admin == true
      );
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Public user lookup (trade/address book) ──────────────────────────────
    // Minimal directory used for recipient lookup during trades.
    match /userLookup/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        (request.auth.uid == uid
          && request.resource.data.keys().hasOnly(['uid', 'emailLower', 'displayName', 'updatedAt']))
        || request.auth.token.admin == true
      );
      allow update: if request.auth != null && (
        (request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'emailLower', 'displayName', 'updatedAt'
          ]))
        || request.auth.token.admin == true
      );
      allow delete: if request.auth != null && (
        request.auth.uid == uid || request.auth.token.admin == true
      );
    }

    // ── Image cache ──────────────────────────────────────────────────────────
    // Stores fal.ai-generated image URLs keyed by layer seed so repeated
    // requests for the same parameters never hit fal.ai again.
    // Anyone may read or create a cache entry; updates are always blocked.
    // Admins (isAdmin: true in their userProfile) may delete entries.
    // The create rule validates document shape to prevent cache poisoning.
    match /imageCache/{cacheKey} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['imageUrl', 'createdAt', 'prompt', 'layer', 'seed'])
        && request.resource.data.imageUrl is string
        && (
          request.resource.data.imageUrl.matches('https://([a-z0-9-]+\\.)*fal\\.media(/.*)?$')
          || request.resource.data.imageUrl.matches('https://firebasestorage\\.googleapis\\.com(/.*)?$')
          || request.resource.data.imageUrl.matches('https://storage\\.googleapis\\.com(/.*)?$')
        )
        && (!request.resource.data.keys().hasAny(['prompt'])
          || (request.resource.data.prompt is string && request.resource.data.prompt.size() <= 512))
        && (!request.resource.data.keys().hasAny(['layer'])
          || (request.resource.data.layer is string && request.resource.data.layer.size() <= 64))
        && (!request.resource.data.keys().hasAny(['seed'])
          || (request.resource.data.seed is string && request.resource.data.seed.size() <= 512));
      allow update: if false;
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Trades ───────────────────────────────────────────────────────────────
    // Both parties can read; only the offerer can create;
    // only the recipient can update status (accept/decline),
    // and the offerer can cancel a pending trade.
    match /trades/{tradeId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid ||
        // Community Market: any signed-in player may browse pending listings
        resource.data.status == 'pending'
      );
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromUid;
      allow update: if request.auth != null && (
        // Recipient accepts/declines
        request.auth.uid == resource.data.toUid ||
        // Offerer cancels while still pending
        (request.auth.uid == resource.data.fromUid
          && resource.data.status == 'pending')
      );
    }
    // ── Referral Claims ──────────────────────────────────────────────────────
    // Written by any visitor who arrives via a referral link.
    // Doc ID format: {referrerUid}_{visitorKey}
    // - Anyone may create a claim (unauthenticated visitors included).
    // - Create is idempotent: if the doc already exists the write is silently
    //   rejected by the "no update" rule.
    // - Only the referrer (authenticated) may read their own claims.
    // - Self-referral is blocked: the write is allowed only when the visitor
    //   is unauthenticated OR is a different user than the referrer.
    match /referralClaims/{claimId} {
      allow read: if request.auth != null
        && resource.data.referrerUid == request.auth.uid;
      allow create: if request.resource.data.keys().hasOnly(['referrerUid', 'visitorKey', 'claimedAt'])
        && request.resource.data.referrerUid is string
        && request.resource.data.visitorKey is string
        // Prevent self-referral for authenticated visitors
        && (request.auth == null || request.auth.uid != request.resource.data.referrerUid);
      allow update, delete: if false;
    }

    // ── Battle Arena ─────────────────────────────────────────────────────────
    // Public arena listings.  Deck stats are NOT stored here — only metadata
    // (name, card count) so opponents cannot see private stats.
    // Any signed-in user can read all entries; only the owner can write/delete.
    match /arena/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // ── Battle Results ───────────────────────────────────────────────────────
    // Any participant can read their own results; writes are server-only.
    match /battleResults/{resultId} {
      allow read:  if request.auth != null && (
        resource.data.challengerUid == request.auth.uid ||
        resource.data.defenderUid == request.auth.uid
      );
      allow create, update, delete: if false;
    }

    // ── Leaderboard ──────────────────────────────────────────────────────────
    // Public leaderboard entries keyed by uid.
    // Any signed-in user may read all entries; only the owner can write their own.
    match /leaderboard/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    // ── Faction images ───────────────────────────────────────────────────────
    // Stores the uploaded background image URL for each faction (keyed by
    // a sanitized faction slug).  Anyone may read; only admins may write.
      match /factionImages/{factionKey} {
      allow read: if true;
      allow write, delete: if request.auth != null
        && request.auth.token.admin == true;
    }

  }
}
